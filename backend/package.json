{
  "name": "@conduit/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../.env.dev -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:stg": "dotenv -e ../.env.stg -- node dist/server.js",
    "start:prod": "dotenv -e ../.env.prod -- node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0 || true",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:push:dev": "dotenv -e ../.env.dev -- prisma db push --skip-generate",
    "prisma:migrate": "dotenv -e ../.env.dev -- prisma migrate deploy",
    "prisma:migrate:init": "dotenv -e ../.env.dev -- prisma migrate dev --name init",
    "prisma:migrate:dev": "dotenv -e ../.env.dev -- prisma migrate dev",
    "prisma:reset": "dotenv -e ../.env.dev -- prisma migrate reset --force",
    "seed:dev": "dotenv -e ../.env.dev -- tsx prisma/seed.ts",
    "seed:stg": "dotenv -e ../.env.stg -- tsx prisma/seed.ts",
    "seed:prod": "dotenv -e ../.env.prod -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.15",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}

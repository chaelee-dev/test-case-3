# Conduit stg profile env (ADR-0037 v1.1)
NODE_ENV=staging
PORT=3000
DATABASE_URL=postgresql://conduit:CHANGEME@stg-host:5432/conduit_stg
JWT_SECRET=CHANGEME-32-byte-random
JWT_EXPIRES_IN=7d
BCRYPT_COST=12
CORS_ORIGIN=https://stg.conduit.example.com
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=60
VITE_API_BASE_URL=https://stg-api.conduit.example.com

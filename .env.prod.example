# Conduit prod profile env (ADR-0037 v1.1)
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://conduit:CHANGEME@prod-host:5432/conduit_prod
JWT_SECRET=CHANGEME-32-byte-random
JWT_EXPIRES_IN=7d
BCRYPT_COST=12
CORS_ORIGIN=https://conduit.example.com
LOG_LEVEL=warn
RATE_LIMIT_PER_MIN=60
VITE_API_BASE_URL=https://api.conduit.example.com
